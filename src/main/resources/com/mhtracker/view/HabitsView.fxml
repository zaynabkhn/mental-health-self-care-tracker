<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mhtracker.controller.HabitsController">

    <content>
        <VBox prefWidth="900.0"
              spacing="18"
              styleClass="app-root">

            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <Label text="Habit Management"
                   styleClass="app-title"/>

            <Label text="Create, update, and manage your self-care habits"
                   styleClass="app-subtitle"/>

            <HBox spacing="12" alignment="CENTER">
                <Button text="Add New Habit"
                        onAction="#handleAddHabit"
                        prefWidth="170"
                        prefHeight="40"
                        styleClass="success-button"/>

                <Button text="Edit Selected"
                        onAction="#handleEditHabit"
                        disable="true"
                        fx:id="editButton"
                        prefWidth="170"
                        prefHeight="40"
                        styleClass="primary-button"/>

                <Button text="Delete Selected"
                        onAction="#handleDeleteHabit"
                        disable="true"
                        fx:id="deleteButton"
                        prefWidth="170"
                        prefHeight="40"
                        styleClass="danger-button"/>

                <Button text="Back to Dashboard"
                        onAction="#goBackToDashboard"
                        prefWidth="190"
                        prefHeight="40"
                        styleClass="secondary-button"/>

                <Button text="Mark Complete Today"
                        onAction="#handleMarkCompleteToday"
                        prefWidth="190"
                        prefHeight="40"
                        styleClass="success-button"/>
            </HBox>

            <ListView fx:id="habitsListView" prefHeight="220.0"/>

            <Label fx:id="streakLabel"
                   text="🕯 Current Streak: 0 days"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1f2d3d;"/>

            <TitledPane fx:id="habitPane"
                        text="Add / Edit Habit"
                        expanded="false">
                <VBox spacing="14">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>

                    <Label text="Habit Name"/>
                    <TextField fx:id="nameField"
                               promptText="e.g., Meditate"
                               prefHeight="36"/>

                    <Label text="Description (optional)"/>
                    <TextArea fx:id="descriptionArea"
                              prefHeight="70"/>

                    <HBox spacing="16">
                        <VBox spacing="6">
                            <Label text="Type"/>
                            <ComboBox fx:id="typeCombo"
                                      promptText="Select type"
                                      prefWidth="160"/>
                        </VBox>

                        <VBox spacing="6">
                            <Label text="Target (for numeric)"/>
                            <TextField fx:id="targetField"
                                       promptText="e.g., 10"
                                       prefWidth="160"/>
                        </VBox>

                        <VBox spacing="6">
                            <Label text="Unit"/>
                            <TextField fx:id="unitField"
                                       promptText="min, glasses, steps"
                                       prefWidth="180"/>
                        </VBox>
                    </HBox>

                    <Label text="Category (optional)"/>
                    <TextField fx:id="categoryField"
                               promptText="Physical, Mental, etc."
                               prefHeight="36"/>

                    <Label text="Weekly Goal (optional)"/>
                    <TextField fx:id="weeklyGoalField"
                               promptText="e.g., 5"
                               prefHeight="36"/>

                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Button text="Save"
                                onAction="#handleSaveHabit"
                                prefWidth="120"
                                prefHeight="38"
                                styleClass="primary-button"/>

                        <Button text="Cancel"
                                onAction="#handleCancelEdit"
                                prefWidth="120"
                                prefHeight="38"
                                styleClass="secondary-button"/>
                    </HBox>
                </VBox>
            </TitledPane>
        </VBox>
    </content>
</ScrollPane>