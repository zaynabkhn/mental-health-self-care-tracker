<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mhtracker.controller.DashboardController"
            stylesheets="@AppStyles.css">

    <content>
        <VBox spacing="15" alignment="CENTER" styleClass="app-root">

            <padding>
                <Insets top="25" right="40" bottom="25" left="40"/>
            </padding>

            <Label text="Mental Health Self-Care Tracker"
                   styleClass="app-title"/>

            <Label text="Welcome to your dashboard!"
                   styleClass="app-subtitle"/>

            <!-- Story 11 weekly summary -->
            <HBox spacing="20" alignment="CENTER">
                <VBox spacing="10" alignment="CENTER"
                      styleClass="card"
                      prefWidth="250">

                    <Label text="Average Mood (7 Days)"
                           styleClass="card-title"/>

                    <Label fx:id="avgMoodLabel"
                           text="--"
                           styleClass="card-value"/>
                </VBox>

                <VBox spacing="10" alignment="CENTER"
                      styleClass="card"
                      prefWidth="250">

                    <Label text="Habits Completed (7 Days)"
                           styleClass="card-title"/>

                    <Label fx:id="habitCompletionLabel"
                           text="--"
                           styleClass="card-value"/>
                </VBox>
            </HBox>

            <Label fx:id="weeklySummaryLabel"
                   style="-fx-font-size: 16px; -fx-text-fill: #5C6B7A;"/>

            <BarChart fx:id="moodChart"
                      title="Mood Over the Last 7 Days"
                      prefWidth="600"
                      prefHeight="220">
                <xAxis>
                    <CategoryAxis label="Date"/>
                </xAxis>
                <yAxis>
                    <NumberAxis fx:id="moodYAxis"/>
                </yAxis>
            </BarChart>

            <!-- Story 10 dashboard overview -->
            <HBox spacing="20" alignment="CENTER">
                <VBox spacing="10" alignment="CENTER"
                      styleClass="card-small"
                      prefWidth="220">

                    <Label text="Total Mood Entries"
                           styleClass="card-title"/>

                    <Label fx:id="totalMoodEntriesLabel"
                           text="--"
                           styleClass="card-value"/>
                </VBox>

                <VBox spacing="10" alignment="CENTER"
                      styleClass="card-small"
                      prefWidth="220">

                    <Label text="Most Frequent Mood"
                           styleClass="card-title"/>

                    <Label fx:id="mostFrequentMoodLabel"
                           text="--"
                           styleClass="card-value"/>
                </VBox>
            </HBox>

            <VBox spacing="8" alignment="CENTER"
                  styleClass="card"
                  prefWidth="620">
                <Label text="Recent Mood Entries"
                       styleClass="card-title"/>
                <ListView fx:id="recentMoodList" prefWidth="520" prefHeight="70"/>
            </VBox>

            <VBox spacing="15" alignment="CENTER"
                  styleClass="card"
                  prefWidth="620">

                <Button fx:id="profileButton"
                        text="Open Profile"
                        onAction="#openProfile"
                        prefWidth="220"
                        prefHeight="42"
                        styleClass="primary-button"/>

                <Button fx:id="habitsButton"
                        text="Open Habits"
                        onAction="#openHabits"
                        prefWidth="220"
                        prefHeight="42"
                        styleClass="primary-button"/>

                <Button fx:id="moodTrackerButton"
                        text="Open Mood Tracker"
                        onAction="#handleOpenMoodTracker"
                        prefWidth="220"
                        prefHeight="42"
                        styleClass="primary-button"/>

                <Button text="Open Journal"
                        onAction="#openJournal"
                        prefWidth="220"
                        prefHeight="42"
                        styleClass="primary-button"/>

                <Region prefHeight="5"/>

                <Button fx:id="logoutButton"
                        text="Logout"
                        onAction="#logout"
                        prefWidth="220"
                        prefHeight="42"
                        styleClass="danger-button"/>
            </VBox>

        </VBox>
    </content>
</ScrollPane>