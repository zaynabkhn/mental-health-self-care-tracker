<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mhtracker.controller.DashboardController"
      styleClass="app-root">

    <padding>
        <Insets top="50" right="40" bottom="50" left="40"/>
    </padding>

    <Label text="Mental Health Self-Care Tracker"
           styleClass="app-title"/>

    <Label text="Welcome to your dashboard!"
           styleClass="app-subtitle"/>

    <Button fx:id="profileButton"
            text="Open Profile"
            onAction="#openProfile"
            prefWidth="220"
            prefHeight="42"
            styleClass="primary-button"/>

    <Button fx:id="habitsButton"
            text="Open Habits"
            onAction="#openHabits"
            prefWidth="220"
            prefHeight="42"
            styleClass="primary-button"/>

    <Button fx:id="logoutButton"
            text="Logout"
            onAction="#logout"
            prefWidth="220"
            prefHeight="42"
            styleClass="danger-button"/>
</VBox>